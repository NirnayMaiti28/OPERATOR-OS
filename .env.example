# CONDUCTOR â€” API Keys
# Copy this file to .env and fill in your values.
# All keys are optional â€” agents that don't need them work without any config.

# Groq (LLM for decomposition + reasoning)
# Get yours at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# OpenWeatherMap (weather tool)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# NewsAPI (news tool)
# Get yours at: https://newsapi.org
NEWSAPI_API_KEY=your_key_here

# GitHub Personal Access Token (GitHub tool)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Alpha Vantage (stock market tool)
# Get yours at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_key_here

# ExchangeRate-API (currency conversion tool)
# Get yours at: https://www.exchangerate-api.com
EXCHANGERATE_API_KEY=your_key_here
